---
import Catalog from "@layouts/Catalog.astro";
import PostsGrid from "@components/PostsGrid.astro";
import Banner from "@components/Banner.astro";
import { getCollection } from "astro:content";
import { type GetStaticPathsOptions } from "astro";
import * as m from "@paraglide/messages.js";
export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = await getCollection("posts");
    const wowEnglishPosts = posts
        .filter((post) => {
            return post.data.lang === "en" && post.data.tags?.includes("wow");
        })
        .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
    return paginate(wowEnglishPosts, { pageSize: 20 });
}
const { page } = Astro.props;
---

<Catalog page={page} title={`${m.NAV_WORDS_OF_WISDOM()} | ${m.GLOBAL_SITE_NAME()}`} description={m.WORDS_OF_WISDOM_BANNER_DESC()} image="/assets/images/wow-banner.webp" bgColor="bg-gray">
    <Banner image="/assets/images/wow-banner.webp" description={m.WORDS_OF_WISDOM_BANNER_DESC()} bgColor="bg-wow-green" />
    <PostsGrid posts={page.data} />
</Catalog>
