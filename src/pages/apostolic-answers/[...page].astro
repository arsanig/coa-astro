---
import Catalog from "@layouts/Catalog.astro";
import PostsGrid from "@components/PostsGrid.astro";
import Banner from "@components/Banner.astro";
import { getCollection } from "astro:content";
import { type GetStaticPathsOptions } from "astro";
import * as m from "@paraglide/messages.js";
export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = await getCollection("posts");
    const aaEnglishPosts = posts
        .filter((post) => {
            return post.data.lang === "en" && post.data.tags?.includes("aa");
        })
        .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
    return paginate(aaEnglishPosts, { pageSize: 20 });
}
const { page } = Astro.props;
---

<Catalog page={page} title={`${m.aaLabel()} | ${m.siteName()}`} bgColor="bg-aa-purple-bg">
    <Banner image="/assets/images/aa-banner.webp" description={m.aaBannerDesc()} bgColor="bg-aa-purple" />
    <PostsGrid posts={page.data} />
</Catalog>
