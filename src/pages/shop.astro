---
import Main from "@layouts/Main.astro";
import Banner from "@components/Banner.astro";
import * as m from "@paraglide/messages.js";

const products = [
    {
        src: "/assets/images/coa-sweatshirt-black.webp",
        alt: "COA Black Sweatshirt",
        href: "https://shop.copticorthodoxanswers.org/products/coa-my-redeemer",
    },
    {
        src: "/assets/images/coa-shirt-mary-navy.webp",
        alt: "COA Navy Mary T-Shirt",
        href: "https://shop.copticorthodoxanswers.org/products/coa-st-mary-navy-youth",
    },
    {
        src: "/assets/images/coa-shirt-jesus-white.webp",
        alt: "COA My Beloved White T-Shirt",
        href: "https://shop.copticorthodoxanswers.org/products/coa-my-beloved",
    },
    {
        src: "/assets/images/coa-sweatshirt-quoted.webp",
        alt: "COA Quoted Sweatshirt",
        href: "https://shop.copticorthodoxanswers.org/products/nation-of-the-cross-hoodie",
    },
];
---

<Main title={`${m.shopLabel()} | ${m.siteName()}`}>
    <Banner image="/assets/images/shop-banner.webp" bgColor="bg-madder-dark" description={m.shopBannerDesc()} />

    <section class="bg-gray min-h-[66vh] overflow-hidden">
        <div class="px-4 sm:px-8 lg:px-12 py-16 sm:py-20 lg:py-28">
            <!-- CTA headline -->
            <div class="text-center mb-12 sm:mb-16 lg:mb-20 shop-reveal">
                <h2 class="font-marcellus text-3xl sm:text-4xl lg:text-5xl xl:text-6xl text-pearl mb-4 sm:mb-6">
                    {m.shopCTA()}
                </h2>
                <p class="font-barlow text-sm sm:text-base lg:text-lg text-pearl/70 max-w-xl mx-auto">
                    {m.shopCTASub()}
                </p>
            </div>

            <!-- Staggered product images -->
            <div class="grid grid-cols-1 sm:grid-cols-12 gap-6 sm:gap-5 lg:gap-6 items-end">
                {
                    products.map((product, i) => {
                        const offsets = [
                            "sm:translate-y-8",
                            "sm:-translate-y-6",
                            "sm:translate-y-12",
                            "sm:-translate-y-2",
                        ];
                        return (
                            <div class={`sm:col-span-3 ${offsets[i]} shop-reveal`}>
                                <a
                                    href={product.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="group block rounded-xl overflow-hidden"
                                >
                                    <div class="relative overflow-hidden rounded-xl">
                                        <img
                                            src={product.src}
                                            alt={product.alt}
                                            class="w-full object-contain transition-transform duration-700 group-hover:scale-105"
                                            loading="lazy"
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                                    </div>
                                </a>
                            </div>
                        );
                    })
                }
            </div>

            <!-- CTA button -->
            <div class="text-center mt-14 sm:mt-20 lg:mt-36 xl:mt-44 shop-reveal">
                <a
                    href="https://shop.copticorthodoxanswers.org/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-8 py-3 sm:px-10 sm:py-4 rounded-md bg-madder-dark text-pearl font-barlow text-base sm:text-lg font-semibold hover:bg-madder-dark transition-colors"
                >
                    {m.visitStore()}
                </a>
            </div>
        </div>
    </section>
</Main>

<style>
    .shop-reveal {
        opacity: 0;
        transform: translateY(50px);
        transition:
            opacity 0.8s ease-out,
            transform 0.8s ease-out;
    }

    .shop-reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .grid > .shop-reveal:nth-child(1) {
        transition-delay: 0ms;
    }
    .grid > .shop-reveal:nth-child(2) {
        transition-delay: 150ms;
    }
    .grid > .shop-reveal:nth-child(3) {
        transition-delay: 300ms;
    }
    .grid > .shop-reveal:nth-child(4) {
        transition-delay: 450ms;
    }
</style>

<script>
    const reveals = document.querySelectorAll(".shop-reveal");
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                    observer.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.15 },
    );
    reveals.forEach((el) => observer.observe(el));
</script>
