---
import Catalog from "@layouts/Catalog.astro";
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import * as m from "@paraglide/messages.js";
export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = await getCollection("posts");
    const ddEnglishPosts = posts
        .filter((post) => {
            return post.data.lang === "en" && post.data.tags?.includes("dd");
        })
        .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
    return paginate(ddEnglishPosts, { pageSize: 20 });
}
const { page } = Astro.props;
---

<Catalog posts={page.data} page={page} title={`${m.ddLabel()} | ${m.siteName()}`} />
