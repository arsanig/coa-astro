---
import { type CollectionEntry, getCollection } from "astro:content";
import Main from "@layouts/Main.astro";
import Post from "@layouts/Post.astro";

export const prerender = true;

export async function getStaticPaths() {
    const allPosts = await getCollection("posts");
    return allPosts
        .filter((post) => post.id.startsWith("fr/words-of-wisdom/"))
        .map((post) => ({
            params: { slug: post.id.replace("fr/words-of-wisdom/", "") },
            props: post,
        }));
}

type Props = CollectionEntry<"posts">;
const post = Astro.props;
---

<Main title={post.data.title} description={`${post.data.title} — Words of Wisdom by Coptic Orthodox Answers.`} image={post.data.imgSrc}>
    <Post {...post} category="words-of-wisdom" />
</Main>
