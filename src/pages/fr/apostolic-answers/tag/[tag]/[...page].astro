---
import Catalog from "@layouts/Catalog.astro";
import PostsGrid from "@components/PostsGrid.astro";
import Banner from "@components/Banner.astro";
import TagFilter from "@components/TagFilter.astro";
import TranslationTooltip from "@components/TranslationTooltip.astro";
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import * as m from "@paraglide/messages.js";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = await getCollection("posts");
    const aaPosts = posts
        .filter((p) => p.data.lang === "fr" && p.data.tags?.includes("aa"))
        .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

    const allTags = [...new Set(aaPosts.flatMap((p) => p.data.tags ?? []).filter((t) => t !== "aa"))].sort();

    return allTags.flatMap((tag) =>
        paginate(
            aaPosts.filter((p) => p.data.tags?.includes(tag)),
            { params: { tag }, pageSize: 20, props: { allTags, activeTag: tag } },
        ),
    );
}

const { page, allTags, activeTag } = Astro.props;
---

<Catalog page={page} title={`${m.aaLabel()} | ${m.siteName()}`} description={m.aaBannerDesc()} image="/assets/images/aa-banner.webp" bgColor="bg-gray">
    <Banner image="/assets/images/aa-banner.webp" description={m.aaBannerDesc()} bgColor="bg-aa-purple" />
    <TranslationTooltip bgColor="bg-aa-purple-bg" />
    <TagFilter tags={allTags} baseUrl="/fr/apostolic-answers" activeTag={activeTag} segmentBg="aa-purple-bg" />
    <PostsGrid posts={page.data} hasTagFilter />
</Catalog>
