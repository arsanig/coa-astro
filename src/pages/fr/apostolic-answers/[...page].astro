---
import Catalog from "@layouts/Catalog.astro";
import PostsGrid from "@components/PostsGrid.astro";
import Banner from "@components/Banner.astro";
import TagFilter from "@components/TagFilter.astro";
import TranslationTooltip from "@components/TranslationTooltip.astro";
import { getCollection } from "astro:content";
import { type GetStaticPathsOptions } from "astro";
import * as m from "@paraglide/messages.js";
export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = await getCollection("posts");
    const aaFrenchPosts = posts
        .filter((post) => {
            return post.data.lang === "fr" && post.data.tags?.includes("aa");
        })
        .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
    const allTags = [...new Set(aaFrenchPosts.flatMap((p) => p.data.tags ?? []).filter((t) => t !== "aa"))].sort();
    return paginate(aaFrenchPosts, { pageSize: 20, props: { allTags } });
}
const { page, allTags } = Astro.props;
---

<Catalog
    page={page}
    title={`${m.NAV_APOSTOLIC_ANSWERS()} | ${m.GLOBAL_SITE_NAME()}`}
    description={m.APOSTOLIC_ANSWERS_BANNER_DESC()}
    image="/assets/images/aa-banner.webp"
    bgColor="bg-gray"
>
    <Banner image="/assets/images/aa-banner.webp" description={m.APOSTOLIC_ANSWERS_BANNER_DESC()} bgColor="bg-aa-purple" />
    <TranslationTooltip bgColor="bg-aa-purple-bg" />
    <TagFilter tags={allTags} baseUrl="/fr/apostolic-answers" segmentBg="aa-purple-bg" />
    <PostsGrid posts={page.data} hasTagFilter />
</Catalog>
