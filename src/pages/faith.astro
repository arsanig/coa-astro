---
import Main from "@layouts/Main.astro";
import * as m from "@paraglide/messages.js";
---

<Main title={`${m.NAV_FAITH()} | ${m.GLOBAL_SITE_NAME()}`} description={m.FAITH_META()} image="/assets/images/generic-banner.webp">
    <div class="flex flex-col gap-px bg-white border border-white">
        <!-- Row 1: Image first on mobile | Text | Image on desktop -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px">
            <div class="flex flex-col justify-center bg-madder-dark px-8 py-16 md:px-12 md:py-36 order-2 md:order-1">
                <h3 class="font-noto text-jonquil text-2xl md:text-3xl mb-4">{m.FAITH_TITLE_1()}</h3>
                <p class="font-barlow text-white text-lg md:text-xl leading-relaxed text-justify">
                    {m.FAITH_BODY_1()}
                </p>
            </div>
            <div
                class="min-h-[300px] sm:min-h-[400px] md:min-h-[600px] bg-cover bg-center order-1 md:order-2"
                style="background-image: url('/assets/images/last-supper.webp');"
            >
            </div>
        </div>

        <!-- Row 2: Image | Text -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px">
            <div class="flex flex-col justify-center bg-pearl px-8 py-16 md:px-12 md:py-36 order-2">
                <h3 class="font-noto text-red-950 text-2xl md:text-3xl mb-4">{m.FAITH_TITLE_2()}</h3>
                <p class="font-barlow text-black text-lg md:text-xl leading-relaxed text-justify">
                    {m.FAITH_BODY_2()}
                </p>
            </div>
            <div
                class="min-h-[300px] sm:min-h-[400px] md:min-h-[600px] bg-cover bg-center order-1"
                style="background-image: url('/assets/images/pope-tawadrous.webp');"
            >
            </div>
        </div>

        <!-- Row 3: Image first on mobile | Text | Image on desktop -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px">
            <div class="flex flex-col justify-center bg-madder-dark px-8 py-16 md:px-12 md:py-36 order-2 md:order-1">
                <h3 class="font-noto text-jonquil text-2xl md:text-3xl mb-4">{m.FAITH_TITLE_3()}</h3>
                <p class="font-barlow text-white text-lg md:text-xl leading-relaxed text-justify">
                    {m.FAITH_BODY_3()}
                </p>
            </div>
            <div
                class="min-h-[300px] sm:min-h-[400px] md:min-h-[600px] bg-cover bg-center order-1 md:order-2"
                style="background-image: url('/assets/images/chalice.webp');"
            >
            </div>
        </div>
    </div>
</Main>
