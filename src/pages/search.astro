---
import Main from "@layouts/Main.astro";
import * as m from "@paraglide/messages.js";
import synonyms from "@utils/synonyms.json";
---

<Main title={`${m.searchResultsLabel()} | ${m.siteName()}`} description={m.searchMeta()} image="/assets/images/generic-banner.webp">
    <div data-pagefind-ignore class="bg-gray min-h-[66vh] px-4 sm:px-8 lg:px-12 xl:px-19 py-8 sm:py-12 lg:py-16">
        <div id="search-results" class="space-y-6">
            <div id="search-header" class="hidden">
                <h3 class="font-noto text-2xl sm:text-3xl text-pearl mb-4 sm:mb-6">
                    {m.searchResultsLabel()}: <span id="search-query" class="text-jonquil"></span>
                </h3>
                <div class="flex flex-row items-center justify-between gap-2 mt-2">
                    <p id="search-count" class="font-barlow text-sm sm:text-base text-pearl/70 order-2 sm:order-1"></p>
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 order-1 sm:order-2">
                        <div class="flex items-center gap-2">
                            <label for="filter" class="font-barlow text-sm text-pearl/70">{m.filterLabel()}</label>
                            <select
                                id="filter"
                                class="appearance-none bg-black/30 text-pearl font-barlow text-sm rounded-md pl-3 pr-10 py-1 border border-pearl/20 focus:outline-none focus:ring-1 focus:ring-jonquil bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%20fill%3D%22%23e8e4d9%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.23%207.21a.75.75%200%20011.06.02L10%2011.168l3.71-3.938a.75.75%200%20111.08%201.04l-4.25%204.5a.75.75%200%2001-1.08%200l-4.25-4.5a.75.75%200%2001.02-1.06z%22%20clip-rule%3D%22evenodd%22%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25rem] bg-[position:right_0.5rem_center] bg-no-repeat"
                            >
                                <option value="">{m.filterAll()}</option>
                                <option value="podcasts">{m.podcastsLabel()}</option>
                                <option value="apostolic-answers">{m.aaLabel()}</option>
                                <option value="deep-dive">{m.ddLabel()}</option>
                                <option value="words-of-wisdom">{m.wowLabel()}</option>
                            </select>
                        </div>
                        <div class="hidden sm:flex items-center gap-2">
                            <label for="per-page" class="font-barlow text-sm text-pearl/70">{m.perPageLabel()}</label>
                            <select
                                id="per-page"
                                class="appearance-none bg-black/30 text-pearl font-barlow text-sm rounded-md pl-3 pr-10 py-1 border border-pearl/20 focus:outline-none focus:ring-1 focus:ring-jonquil bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%20fill%3D%22%23e8e4d9%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.23%207.21a.75.75%200%20011.06.02L10%2011.168l3.71-3.938a.75.75%200%20111.08%201.04l-4.25%204.5a.75.75%200%2001-1.08%200l-4.25-4.5a.75.75%200%2001.02-1.06z%22%20clip-rule%3D%22evenodd%22%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25rem] bg-[position:right_0.5rem_center] bg-no-repeat"
                            >
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div id="search-loading" class="text-center py-12">
                <div class="inline-block w-10 h-10 border-4 border-pearl/20 border-t-jonquil rounded-full animate-spin">
                </div>
            </div>
            <div id="search-empty" class="hidden text-center py-12">
                <span class="font-barlow text-lg text-pearl">{m.noResultsFound()}</span>
            </div>
            <div id="results-list" class="grid grid-cols-1 gap-6"></div>
            <div id="pagination" class="hidden"></div>
        </div>
    </div>

    <template id="result-card-template">
        <a
            class="group flex flex-col sm:flex-row sm:items-stretch gap-3 sm:gap-4 bg-black/30 rounded-lg p-3 sm:p-4 hover:bg-black/50 transition-colors"
        >
            <div data-slot="thumb" class="shrink-0 w-full sm:w-48 rounded-md overflow-hidden hidden">
                <div class="aspect-video">
                    <img data-slot="img" alt="" class="w-full h-full object-cover" loading="lazy" />
                </div>
            </div>
            <div class="min-w-0 flex-1">
                <h3
                    data-slot="title"
                    class="font-barlow text-lg sm:text-xl text-pearl group-hover:underline group-hover:underline-offset-4"
                >
                </h3>
                <p data-slot="excerpt" class="font-barlow text-sm sm:text-base text-pearl/70 mt-2 sm:line-clamp-[7]">
                </p>
            </div>
        </a>
    </template>

    <template id="page-btn-template">
        <a
            class="px-3 py-2 sm:px-4 sm:py-2 rounded-md transition-colors text-sm md:text-base bg-pearl text-black hover:bg-madder hover:text-white"
        >
        </a>
    </template>

    <template id="page-active-template">
        <span
            class="px-3 py-2 sm:px-4 sm:py-2 rounded-md transition-colors text-sm md:text-base bg-madder text-white pointer-events-none"
            aria-current="page"
        >
        </span>
    </template>

    <template id="page-ellipsis-template">
        <span class="text-pearl text-sm md:text-base">...</span>
    </template>
</Main>

<style is:global>
    #results-list mark {
        background: transparent;
        color: var(--color-jonquil);
    }
</style>

<script id="synonyms-data" type="application/json" set:html={JSON.stringify(synonyms)} />
<script is:inline>
    (() => {
        const MAX_VISIBLE_PAGES = 5;
        const VALID_SIZES = [10, 20, 50];

        const params = new URLSearchParams(window.location.search);
        const query = params.get("q") || "";
        let currentPage = parseInt(params.get("page") || "1", 10);
        const isMobile = window.innerWidth < 640;
        const rawSize = parseInt(params.get("per_page") || "10", 10);
        const PAGE_SIZE = isMobile ? "all" : VALID_SIZES.includes(rawSize) ? rawSize : 10;
        const VALID_FILTERS = ["apostolic-answers", "deep-dive", "words-of-wisdom", "podcasts"];
        const rawFilter = params.get("filter") || "";
        const activeFilter = VALID_FILTERS.includes(rawFilter) ? rawFilter : "";

        const searchInput = document.querySelector("#search");
        if (searchInput && query) searchInput.value = query;

        const searchHeaderEl = document.getElementById("search-header");
        const searchQueryEl = document.getElementById("search-query");
        const searchCountEl = document.getElementById("search-count");
        const filterSelect = document.getElementById("filter");
        const perPageSelect = document.getElementById("per-page");
        const loadingEl = document.getElementById("search-loading");
        const emptyEl = document.getElementById("search-empty");
        const listEl = document.getElementById("results-list");
        const paginationEl = document.getElementById("pagination");

        const cardTemplate = document.getElementById("result-card-template");
        const pageBtnTemplate = document.getElementById("page-btn-template");
        const pageActiveTemplate = document.getElementById("page-active-template");
        const pageEllipsisTemplate = document.getElementById("page-ellipsis-template");

        const buildUrl = (overrides = {}) => {
            const prefix = window.location.pathname.startsWith("/fr") ? "/fr" : "";
            const f = overrides.filter !== undefined ? overrides.filter : activeFilter;
            const pp = overrides.per_page !== undefined ? overrides.per_page : PAGE_SIZE;
            const pg = overrides.page !== undefined ? overrides.page : 1;
            let url = prefix + "/search?q=" + encodeURIComponent(query);
            if (f) url += "&filter=" + f;
            if (pp !== 10 && pp !== "all") url += "&per_page=" + pp;
            if (pg > 1) url += "&page=" + pg;
            return url;
        };

        filterSelect.value = activeFilter;
        perPageSelect.value = PAGE_SIZE.toString();

        filterSelect.addEventListener("change", () => {
            window.location.href = buildUrl({ filter: filterSelect.value });
        });
        perPageSelect.addEventListener("change", () => {
            window.location.href = buildUrl({ per_page: parseInt(perPageSelect.value, 10) });
        });

        if (query.trim()) {
            searchQueryEl.textContent = query;
            searchHeaderEl.classList.remove("hidden");
        }

        if (!query.trim()) {
            loadingEl.classList.add("hidden");
            emptyEl.classList.remove("hidden");
            return;
        }

        const createCard = (data) => {
            const card = cardTemplate.content.cloneNode(true);
            const link = card.querySelector("a");
            const thumb = card.querySelector("[data-slot='thumb']");
            const img = card.querySelector("[data-slot='img']");
            const title = card.querySelector("[data-slot='title']");
            const excerpt = card.querySelector("[data-slot='excerpt']");

            link.href = data.url;
            title.textContent = data.meta.title || "";
            // Pagefind excerpts contain <mark> tags for keyword highlighting
            excerpt.innerHTML = data.excerpt || "";

            if (data.meta.image) {
                img.src = data.meta.image;
                thumb.classList.remove("hidden");
            }

            return card;
        };

        const createPageBtn = (page, href) => {
            const btn = pageBtnTemplate.content.cloneNode(true);
            const link = btn.querySelector("a");
            link.href = href;
            link.textContent = page;
            return btn;
        };

        const createActiveBtn = (page) => {
            const btn = pageActiveTemplate.content.cloneNode(true);
            const span = btn.querySelector("span");
            span.textContent = page;
            return btn;
        };

        const createEllipsis = () => pageEllipsisTemplate.content.cloneNode(true);

        const renderPagination = (totalPages) => {
            if (totalPages <= 1) return;

            const container = document.createElement("div");
            container.className = "flex justify-center items-center gap-1 sm:gap-2 py-19";

            const start = Math.max(1, Math.min(currentPage - 2, totalPages - MAX_VISIBLE_PAGES + 1));
            const end = Math.min(totalPages, start + MAX_VISIBLE_PAGES - 1);

            if (start > 1) {
                container.appendChild(createPageBtn(1, buildUrl({ page: 1 })));
                if (start > 2) container.appendChild(createEllipsis());
            }

            for (let p = start; p <= end; p++) {
                container.appendChild(p === currentPage ? createActiveBtn(p) : createPageBtn(p, buildUrl({ page: p })));
            }

            if (end < totalPages) {
                if (end < totalPages - 1) container.appendChild(createEllipsis());
                container.appendChild(createPageBtn(totalPages, buildUrl({ page: totalPages })));
            }

            paginationEl.replaceChildren(container);
            paginationEl.classList.remove("hidden");
        };

        const SYNONYMS = JSON.parse(document.getElementById("synonyms-data").textContent);

        const isWordBoundary = (str, start, len) => {
            const before = start === 0 || /[\s.,;:!?'"-]/.test(str[start - 1]);
            const after = start + len >= str.length || /[\s.,;:!?'"-]/.test(str[start + len]);
            return before && after;
        };

        const expandQuery = (q) => {
            const results = new Set([q]);
            const expand = (current) => {
                const lower = current.toLowerCase();
                for (const group of SYNONYMS) {
                    for (const term of group) {
                        const idx = lower.indexOf(term);
                        if (idx === -1 || !isWordBoundary(lower, idx, term.length)) continue;
                        for (const alt of group) {
                            if (alt === term) continue;
                            const variant = current.slice(0, idx) + alt + current.slice(idx + term.length);
                            if (!results.has(variant)) {
                                results.add(variant);
                                expand(variant);
                            }
                        }
                        break;
                    }
                }
            };
            expand(q);
            return [...results];
        };

        const runSearch = async () => {
            try {
                const pagefind = await import("/pagefind/pagefind.js");
                const filterOptions = activeFilter ? { filters: { category: [activeFilter] } } : {};
                const quoted = (q) => (q.startsWith('"') && q.endsWith('"') ? q : '"' + q + '"');
                const queries = expandQuery(query);
                const searches = await Promise.all(queries.map((q) => pagefind.search(quoted(q), filterOptions)));

                const seen = new Set();
                const dedupedResults = [];
                for (const search of searches) {
                    for (const result of search.results) {
                        if (!seen.has(result.id)) {
                            seen.add(result.id);
                            dedupedResults.push(result);
                        }
                    }
                }

                const allData = await Promise.all(dedupedResults.map((r) => r.data({ excerptLength: 500 })));
                const lowerQueries = queries.map((q) => q.toLowerCase());
                const filtered = allData.filter((d) => {
                    const title = (d.meta.title || "").toLowerCase();
                    return lowerQueries.some((q) => title.includes(q));
                });
                const totalResults = filtered.length;

                if (!totalResults) {
                    loadingEl.classList.add("hidden");
                    searchCountEl.textContent = "0 results";
                    emptyEl.classList.remove("hidden");
                    return;
                }

                const showAll = PAGE_SIZE === "all";
                const perPage = showAll ? totalResults : PAGE_SIZE;
                const totalPages = showAll ? 1 : Math.ceil(totalResults / perPage);
                if (currentPage > totalPages) currentPage = totalPages;

                const startIdx = showAll ? 0 : (currentPage - 1) * perPage;
                const pageData = showAll ? filtered : filtered.slice(startIdx, startIdx + perPage);
                const rangeStart = startIdx + 1;
                const rangeEnd = startIdx + pageData.length;
                searchCountEl.textContent = showAll
                    ? totalResults + " result" + (totalResults !== 1 ? "s" : "")
                    : "Showing " +
                      rangeStart +
                      "\u2013" +
                      rangeEnd +
                      " of " +
                      totalResults +
                      " result" +
                      (totalResults !== 1 ? "s" : "");

                const fragment = document.createDocumentFragment();
                for (const data of pageData) {
                    fragment.appendChild(createCard(data));
                }

                listEl.replaceChildren(fragment);
                renderPagination(totalPages);
                loadingEl.classList.add("hidden");
            } catch (e) {
                loadingEl.classList.add("hidden");
                emptyEl.classList.remove("hidden");
            }
        };

        runSearch();

        const backToTop = document.getElementById("back-to-top");
        if (backToTop) {
            window.addEventListener(
                "scroll",
                () => {
                    if (window.scrollY > 300) {
                        backToTop.classList.remove("hidden");
                        requestAnimationFrame(() => {
                            backToTop.classList.remove("opacity-0", "translate-y-4");
                            backToTop.classList.add("opacity-100", "translate-y-0");
                        });
                    } else {
                        backToTop.classList.add("opacity-0", "translate-y-4");
                        backToTop.classList.remove("opacity-100", "translate-y-0");
                        backToTop.addEventListener(
                            "transitionend",
                            () => {
                                if (window.scrollY <= 300) backToTop.classList.add("hidden");
                            },
                            { once: true },
                        );
                    }
                },
                { passive: true },
            );

            backToTop.addEventListener("click", () => {
                window.scrollTo({ top: 0, behavior: "smooth" });
            });
        }
    })();
</script>
