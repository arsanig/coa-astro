---
const { active, text, route } = Astro.props;
const activeRoute = active ? "text-madder underline underline-offset-4 sm:underline-offset-8" : "text-black";
---

<a
    href={route}
    class={`${activeRoute} font-barlow text-left lg:text-center text-nowrap px-8 lg:px-4 py-4 w-full bg-pearl hover:bg-madder hover:text-white hover:no-underline text-xl lg:text-[0.8rem] xl:text-lg transition-colors duration-200 lg:h-full lg:flex lg:justify-evenly`}
>
    {text}
</a>
