---
import { Image } from "astro:assets";

interface Props {
    image: string;
    description: string;
    bgColor?: string;
}

const { image, description, bgColor = "bg-black" } = Astro.props;
---

<div
    class:list={[bgColor, "w-full flex flex-col sm:flex-row justify-center items-center h-auto sm:h-40 md:h-44 lg:h-48 xl:h-52 2xl:h-60 px-4 sm:px-8 lg:px-12 py-6 sm:py-0 gap-3 sm:gap-4 lg:gap-6"]}
>
    <Image src={image} alt="" width={200} height={200} class="h-28 sm:h-24 md:h-28 lg:h-32 xl:h-36 2xl:h-full w-auto object-contain" loading="eager" />
    <div class="flex flex-col justify-center items-center sm:items-start gap-3 max-w-md sm:py-4">
        <p class="font-inknut font-light italic text-base sm:text-lg md:text-sm lg:text-base xl:text-lg 2xl:text-xl leading-loose sm:leading-loose text-jonquil text-center sm:text-left">
            {description}
        </p>
    </div>
</div>
