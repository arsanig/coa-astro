---
import YouTubeButton from "./YouTubeButton.astro";

interface Props {
    image: string;
    description: string;
}

const { image, description } = Astro.props;
---

<div
    class="bg-black w-full flex flex-col sm:flex-row justify-center items-center h-auto sm:h-36 md:h-44 lg:h-48 px-4 sm:px-8 lg:px-12 py-6 sm:py-0 gap-3 sm:gap-4 lg:gap-6"
>
    <img src={image} alt="" class="h-20 sm:h-full w-auto object-contain" />
    <div class="flex flex-col justify-center items-center sm:items-start gap-3 max-w-md sm:py-4">
        <p class="font-barlow text-base sm:text-lg lg:text-xl leading-relaxed text-jonquil text-center sm:text-left">
            {description}
        </p>
        <YouTubeButton />
    </div>
</div>
