---
import NavLink from "./NavLink.astro";
import Socials from "./Socials.astro";
import { localizePathname } from "@utils/linking";
import { getLocale } from "@paraglide/runtime";
import * as m from "@paraglide/messages.js";
const rawPathname = Astro.url.pathname;
const pathname = rawPathname === "/" ? "/" : rawPathname.replace(/\/$/, "");

const homeLocalized = localizePathname("/", getLocale());
const wowLocalized = localizePathname("/words-of-wisdom", getLocale());
const aaLocalized = localizePathname("/apostolic-answers", getLocale());
const ddLocalized = localizePathname("/deep-dive", getLocale());
const podLocalized = localizePathname("/podcasts", getLocale());
const shortsLocalized = localizePathname("/shorts", getLocale());
const faithLocalized = localizePathname("/faith", getLocale());
const contactLocalized = localizePathname("/contact", getLocale());
const shopLocalized = localizePathname("/shop", getLocale());
---

<nav class="w-full">
    <!-- Mobile menu button -->
    <button
        id="mobile-menu-button"
        class="lg:hidden fixed top-4 right-4 z-40 p-2 rounded-md hover:bg-madder text-pearl transition-colors bg-pearl/10 backdrop-blur-sm"
        aria-label="Toggle menu"
    >
        <svg class="w-9 h-9" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
    </button>

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-black/50 z-50 hidden"></div>

    <!-- Navigation links -->
    <div
        id="nav-links"
        class="fixed lg:static inset-y-0 right-0 w-64 lg:w-full transition-transform duration-300 ease-in-out z-50 lg:z-auto flex flex-col lg:flex-row lg:justify-center lg:items-center overflow-y-auto lg:overflow-y-visible scrollbar-none"
    >
        <NavLink active={pathname === homeLocalized} text={m.homeLabel()} route={homeLocalized} />
        <NavLink active={pathname.startsWith(podLocalized)} text={m.podcastsLabel()} route={podLocalized} />
        <NavLink active={pathname.startsWith(shortsLocalized)} text={m.shortsLabel()} route={shortsLocalized} />
        <NavLink active={pathname.startsWith(aaLocalized)} text={m.aaLabel()} route={aaLocalized} />
        <NavLink active={pathname.startsWith(ddLocalized)} text={m.ddLabel()} route={ddLocalized} />
        <NavLink active={pathname.startsWith(wowLocalized)} text={m.wowLabel()} route={wowLocalized} />
        <NavLink active={pathname.startsWith(faithLocalized)} text={m.faithLabel()} route={faithLocalized} />
        <NavLink active={pathname.startsWith(shopLocalized)} text={m.shopLabel()} route={shopLocalized} />
        <NavLink active={pathname.startsWith(contactLocalized)} text={m.contactLabel()} route={contactLocalized} />
        <Socials
            class="flex lg:hidden flex-row gap-3 mt-auto pt-4 pb-6 px-8 justify-start [&_img]:w-7 [&_img]:h-7"
            animate
        />
    </div>
</nav>

<style>
    @reference "@styles/global.css";

    #nav-links {
        @apply invisible translate-x-full bg-transparent;
    }
    #nav-links.open {
        @apply visible translate-x-0 bg-pearl;
    }
    @media (min-width: 1024px) {
        #nav-links {
            @apply visible translate-x-0;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const menuButton = document.getElementById("mobile-menu-button");
        const mobileMenu = document.getElementById("mobile-menu");
        const navLinks = document.getElementById("nav-links");

        if (!menuButton || !mobileMenu || !navLinks) {
            console.error("Required navigation elements not found");
            return;
        }

        let isMenuOpen = false;

        function animateSocials(show: boolean) {
            navLinks!.querySelectorAll("[data-social-item]").forEach((el) => {
                const htmlEl = el as HTMLElement;
                if (show) {
                    requestAnimationFrame(() => {
                        htmlEl.style.opacity = "1";
                        htmlEl.style.transform = "translateX(0)";
                    });
                } else {
                    htmlEl.style.opacity = "0";
                    htmlEl.style.transform = "translateX(30px)";
                }
            });
        }

        function openMenu() {
            if (isMenuOpen) return;
            isMenuOpen = true;
            mobileMenu!.classList.remove("hidden");
            navLinks!.classList.add("open");
            document.body.classList.add("overflow-hidden");
            animateSocials(true);
        }

        function closeMenu() {
            if (!isMenuOpen) return;
            isMenuOpen = false;
            mobileMenu!.classList.add("hidden");
            navLinks!.classList.remove("open");
            document.body.classList.remove("overflow-hidden");
            animateSocials(false);
        }

        menuButton.addEventListener("click", () => (isMenuOpen ? closeMenu() : openMenu()));
        mobileMenu.addEventListener("click", closeMenu);
        mobileMenu.addEventListener("touchend", (e) => {
            e.preventDefault();
            closeMenu();
        });
        navLinks.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));
    });
</script>
