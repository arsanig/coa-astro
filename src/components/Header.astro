---
import Nav from "./Nav.astro";
import LanguageToggle from "./LanguageToggle.astro";
import * as m from "@paraglide/messages.js";
import SearchIcon from "./SearchIcon.astro";
import { Image } from "astro:assets";
import coaLogo from "/public/assets/images/coa-logo-coloured.svg";
import Socials from "./Socials.astro";
---

<header data-pagefind-ignore>
    <!-- <div class="absolute top-4 left-4 z-50">
        <LanguageToggle />
    </div> -->
    <div class="bg-no-repeat bg-cover bg-center bg-[url(/assets/images/church.webp)]">
        <div class="bg-black/85 min-h-96 relative flex flex-col justify-center items-center px-4 py-8">
            <a
                href="/"
                class="md:absolute md:left-[8%] lg:left-[20%] md:top-1/2 md:-translate-y-1/2 shrink-0 mb-4 md:mb-0"
            >
                <Image src={coaLogo} alt="Coptic Orthodox Answers" class="w-8 md:w-16 lg:w-20 h-auto animate-glow" loading="eager" />
            </a>
            <Socials class="hidden md:flex flex-col gap-3 absolute right-4 lg:right-6 top-1/2 -translate-y-1/2" dark />
            <div class="flex flex-col items-center">
                <a href="/">
                    <h1 class="font-noto text-3xl md:text-5xl lg:text-7xl text-pearl text-center mt-4 md:mt-0">
                        {m.siteName()}
                    </h1>
                    <h2
                        class="font-barlow text-xl md:text-3xl lg:text-5xl mt-4 md:mt-6 lg:mt-8 text-jonquil text-center"
                    >
                        {m.slogan()}
                    </h2>
                </a>
                <div class="mt-12 md:mt-14 lg:mt-16 w-[75vw] sm:w-full max-w-2xl relative flex justify-center">
                    <div class="relative w-full sm:w-4/5 md:w-2/3">
                        <input
                            id="search"
                            type="text"
                            placeholder={m.searchPlaceholder()}
                            class="w-full px-[1.875rem] sm:px-12 py-[0.47rem] sm:py-3 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-jonquil text-center text-[0.75rem] sm:text-base [&:focus::placeholder]:opacity-0"
                        />
                        <div
                            class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
                        >
                            <SearchIcon class="w-3 h-3 sm:w-5 sm:h-5" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
<nav class="bg-pearl flex flex-row justify-around w-full">
    <Nav />
</nav>

<script is:inline>
    (() => {
        const searchBox = document.querySelector("#search");
        if (!searchBox) return;

        const navigateToSearch = (query) => {
            const q = query.trim();
            if (!q) return;
            const prefix = window.location.pathname.startsWith("/fr") ? "/fr" : "";
            window.location.href = prefix + "/search?q=" + encodeURIComponent(q);
        };

        searchBox.addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                navigateToSearch(e.target.value);
            }
        });
    })();
</script>
