---
import Nav from "./Nav.astro";
import LanguageToggle from "./LanguageToggle.astro";
import * as m from "@paraglide/messages.js";
import SearchIcon from "./SearchIcon.astro";
import { Image } from "astro:assets";
import coaLogo from "/public/assets/images/coa-logo-coloured.svg";
import Socials from "./Socials.astro";
import { localizePathname } from "@utils/linking";
import { getLocale } from "@paraglide/runtime";

const homeLink = localizePathname("/", getLocale());
---

<header data-pagefind-ignore>
    <div class="absolute top-4 left-4 z-50">
        <LanguageToggle />
    </div>
    <div class="bg-no-repeat bg-cover bg-center bg-[url(/assets/images/church.webp)]">
        <div class="bg-black/85 min-h-96 relative flex flex-col justify-center items-center px-4 py-8">
            <a
                href={homeLink}
                class="shrink-0 md:absolute md:left-[12%] lg:left-[10%] xl:left-[11%] 2xl:left-[13%]"
                id="header-logo"
            >
                <Image
                    src={coaLogo}
                    alt="Coptic Orthodox Answers"
                    class="w-8 md:w-12 lg:w-16 xl:w-16 2xl:w-20 h-auto animate-glow"
                    loading="eager"
                />
            </a>
            <Socials
                class="hidden lg:flex flex-col gap-3 absolute right-4 lg:right-6 top-[47%] -translate-y-1/2"
                dark
            />
            <div class="flex flex-col items-center" id="header-content">
                <a href={homeLink}>
                    <h1
                        class="font-noto text-3xl md:text-4xl lg:text-5xl xl:text-5xl 2xl:text-7xl text-pearl text-center mt-4 md:mt-0"
                    >
                        {m.siteName()}
                    </h1>
                    <h2
                        class="font-barlow text-xl md:text-2xl lg:text-3xl xl:text-3xl 2xl:text-5xl mt-4 md:mt-4 lg:mt-5 xl:mt-5 2xl:mt-8 text-jonquil text-center"
                    >
                        {m.slogan()}
                    </h2>
                </a>
                <div
                    class="mt-12 md:mt-14 lg:mt-16 w-full px-2 sm:px-0 sm:w-full max-w-2xl xl:max-w-2xl lg:max-w-lg relative flex justify-center"
                >
                    <div class="relative w-full md:w-2/3 lg:w-3/4">
                        <input
                            id="search"
                            type="text"
                            placeholder={m.searchPlaceholder()}
                            class="w-full px-4 sm:px-10 md:px-4 xl:px-12 py-2 sm:py-3 md:py-1.5 xl:py-3 rounded-lg bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-jonquil text-center text-xs sm:text-base md:text-xs xl:text-base [&:focus::placeholder]:opacity-0"
                        />
                        <div
                            class="absolute left-2.5 sm:left-3 md:left-2 xl:left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
                        >
                            <SearchIcon class="w-4 h-4 sm:w-4 sm:h-4 md:w-4 md:h-4 xl:w-5 xl:h-5" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
<nav class="bg-pearl flex flex-row justify-around w-full">
    <Nav />
</nav>

<script is:inline>
    (() => {
        const searchBox = document.querySelector("#search");
        if (searchBox) {
            const navigateToSearch = (query) => {
                const q = query.trim();
                if (!q) return;
                const prefix = window.location.pathname.startsWith("/fr") ? "/fr" : "";
                window.location.href = prefix + "/search?q=" + encodeURIComponent(q);
            };

            searchBox.addEventListener("keypress", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    navigateToSearch(e.target.value);
                }
            });
        }

        const alignLogo = () => {
            const logo = document.getElementById("header-logo");
            const content = document.getElementById("header-content");
            if (!logo || !content || window.innerWidth < 768) {
                if (logo) logo.style.top = "";
                return;
            }
            const h1 = content.querySelector("h1");
            if (!h1) return;
            logo.style.top = h1.getBoundingClientRect().top - logo.parentElement.getBoundingClientRect().top + "px";
        };
        alignLogo();
        window.addEventListener("resize", alignLogo);
    })();
</script>

<style is:global>
    @supports (-webkit-touch-callout: none) {
        /* Prevent iOS Safari zoom on focus - using 16px minimum only when focused */
        #search:focus {
            font-size: 16px;
        }
    }
</style>
